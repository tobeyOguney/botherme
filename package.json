{
  "name": "botherme",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A Telegram bot that manufactures salience for silent obligations.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "replay": "tsx scripts/replay-turn.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "grammy": "^1.30.0",
    "@grammyjs/auto-retry": "^2.0.2",
    "node-cron": "^3.0.3",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
