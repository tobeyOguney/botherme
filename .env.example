# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=12345:ABC...

# --- Paths (defaulted; override only for non-standard layouts) ---
BOTHERME_DATA_DIR=./data
BOTHERME_USERS_DIR=./users
BOTHERME_TRACES_DIR=./traces
BOTHERME_PROMPTS_DIR=./prompts

# --- Behavior ---
# Global kill-switch for outbound nudges. true = scheduler short-circuits.
BOTHERME_SCHEDULER_PAUSED=false

# pino log level: debug | info | warn | error
BOTHERME_LOG_LEVEL=info

# Comma-separated Telegram chat IDs allowed to use the bot.
# Empty = closed (everyone gets a polite "not yet" reply).
BOTHERME_ALLOWED_TELEGRAM_USERS=

# --- Models (override for cost experiments) ---
BOTHERME_MODEL_MAIN=claude-sonnet-4-5
BOTHERME_MODEL_RECALL=claude-haiku-4-5
BOTHERME_MODEL_PUSHBACK=claude-haiku-4-5
